{
  "name": "cookbook-next",
  "description": "A recipe sharing platform built with Next.js, Apollo Server, and Neon (Serverless Postgres).",
  "author": "Daniel Maros",
  "license": "MIT",
  "version": "2.33.1",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/marosdaniel/cookbook-next.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "prisma generate && next build",
    "typecheck": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "deps:update": "pnpm dlx npm-check-updates -u"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@apollo/server": "^5.5.1",
    "@as-integrations/next": "^4.1.0",
    "@mantine/carousel": "9.2.1",
    "@mantine/core": "9.2.1",
    "@mantine/form": "9.2.1",
    "@mantine/hooks": "9.2.1",
    "@mantine/modals": "9.2.1",
    "@mantine/notifications": "9.2.1",
    "@mantine/nprogress": "9.2.1",
    "@mantine/spotlight": "^9.2.1",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.44.0",
    "@types/uuid": "^11.0.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "isomorphic-dompurify": "^3.13.0",
    "graphql": "17.0.0-alpha.9",
    "graphql-depth-limit": "^1.1.0",
    "graphql-scalars": "^1.25.0",
    "graphql-tag": "^2.12.6",
    "mantine-form-zod-resolver": "^1.3.0",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.30",
    "next-intl": "^4.12.0",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^8.0.7",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-redux": "^9.3.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@playwright/test": "^1.60.0",
    "@prisma/config": "^7.8.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "4.1.6",
    "baseline-browser-mapping": "^2.10.30",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.9.0",
    "prisma": "7.8.0",
    "semantic-release": "^25.0.3",
    "typescript": "6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
