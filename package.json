{
  "name": "cookbook-next",
  "description": "A recipe sharing platform built with Next.js, Apollo Server, and Neon (Serverless Postgres).",
  "author": "Daniel Maros",
  "license": "MIT",
  "version": "2.53.0",
  "type": "module",
  "private": true,
  "overrides": {
    "fast-uri": "^4.1.1",
    "sharp": "^0.35.3",
    "next>sharp": "^0.35.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marosdaniel/cookbook-next.git"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.15.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "prisma generate && next build",
    "typecheck": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "deps:update": "pnpm dlx npm-check-updates -u",
    "deps:update:without-ts": "pnpm dlx npm-check-updates -u --reject typescript",
    "analyze": "pnpm prisma generate && next build --experimental-analyze",
    "audit:fix": "pnpm audit --fix=update || pnpm audit --fix=override"
  },
  "dependencies": {
    "@apollo/client": "^4.2.7",
    "@apollo/server": "^5.5.1",
    "@as-integrations/next": "^4.1.0",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@mantine/carousel": "9.4.2",
    "@mantine/core": "9.4.2",
    "@mantine/form": "9.4.2",
    "@mantine/hooks": "9.4.2",
    "@mantine/modals": "9.4.2",
    "@mantine/notifications": "9.4.2",
    "@mantine/nprogress": "9.4.2",
    "@mantine/spotlight": "^9.4.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.9.0",
    "@prisma/client": "7.9.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.45.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "argon2": "^0.45.1",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "graphql": "17.0.2",
    "graphql-scalars": "^1.25.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "motion": "^12.42.2",
    "next": "16.2.11",
    "next-auth": "5.0.0-beta.32",
    "next-intl": "^4.13.3",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^9.0.3",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "sanitize-html": "^2.17.6",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@playwright/test": "^1.61.1",
    "@prisma/config": "^7.9.0",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/git": "^11.0.0",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.4",
    "@vitest/coverage-v8": "4.1.10",
    "baseline-browser-mapping": "^2.11.0",
    "dotenv": "^17.4.2",
    "fast-uri": "^4.1.1",
    "happy-dom": "^20.11.0",
    "prisma": "7.9.0",
    "semantic-release": "^25.0.8",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
