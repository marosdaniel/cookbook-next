{
  "name": "cookbook-next",
  "description": "A recipe sharing platform built with Next.js, Apollo Server, and Neon (Serverless Postgres).",
  "author": "Daniel Maros",
  "license": "MIT",
  "version": "2.34.1",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/marosdaniel/cookbook-next.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "start": "next start",
    "build": "prisma generate && next build",
    "typecheck": "prisma generate && tsc --noEmit",
    "postinstall": "prisma generate",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "test:integration": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "deps:update": "pnpm dlx npm-check-updates -u",
    "analyze": "pnpm prisma generate && next build --experimental-analyze",
    "audit:fix": "pnpm audit --fix=update || pnpm audit --fix"
  },
  "dependencies": {
    "@apollo/client": "^4.2.5",
    "@apollo/server": "^5.5.1",
    "@as-integrations/next": "^4.1.0",
    "@escape.tech/graphql-armor": "^3.2.0",
    "@mantine/carousel": "9.4.1",
    "@mantine/core": "9.4.1",
    "@mantine/form": "9.4.1",
    "@mantine/hooks": "9.4.1",
    "@mantine/modals": "9.4.1",
    "@mantine/notifications": "9.4.1",
    "@mantine/nprogress": "9.4.1",
    "@mantine/spotlight": "^9.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tabler/icons-react": "^3.44.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "dataloader": "^2.2.3",
    "graphql": "17.0.2",
    "graphql-scalars": "^1.25.0",
    "isomorphic-dompurify": "^3.18.0",
    "mantine-form-zod-resolver": "^1.3.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.13.1",
    "nextjs-toploader": "^3.9.17",
    "nodemailer": "^9.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "^1.61.1",
    "@prisma/config": "^7.8.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "baseline-browser-mapping": "^2.10.41",
    "dotenv": "^17.4.2",
    "happy-dom": "^20.10.6",
    "prisma": "7.8.0",
    "semantic-release": "^25.0.5",
    "typescript": "6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
