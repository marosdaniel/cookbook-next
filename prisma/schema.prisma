// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  USER
  BLOGGER
}

// User model
model User {
  id                   String    @id @default(cuid())
  firstName            String
  lastName             String
  userName             String    @unique
  email                String    @unique
  password             String
  locale               String    @default("en-gb")
  role                 UserRole  @default(USER)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  recipes           Recipe[] @relation("UserRecipes")
  favoriteRecipes   Recipe[] @relation("UserFavorites")
  ratings           Rating[]

  @@map("users")
}

// Recipe model
model Recipe {
  id               String            @id @default(cuid())
  title            String
  description      String?
  category         Json?             // Továbbá a metadata_offline.json-ban leírt struktúra szerint
  labels           Json?             // Továbbá a metadata_offline.json-ban leírt struktúra szerint
  imgSrc           String?
  cookingTime      Int
  difficultyLevel  Json?             // Továbbá a metadata_offline.json-ban leírt struktúra szerint
  servings         Int
  youtubeLink      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  ingredients      Ingredient[]
  preparationSteps PreparationStep[]
  
  // Author relation
  createdBy String
  author    User   @relation("UserRecipes", fields: [createdBy], references: [id])

  // Favorite relation
  favoritedBy    User[]   @relation("UserFavorites")

  // Ratings
  ratings Rating[]

  @@map("recipes")
}

// Ingredient model (New Model for SQL)
model Ingredient {
  id       String  @id @default(cuid())
  localId  String
  name     String
  quantity Float
  unit     String
  
  // Relation back to Recipe
  recipeId String
  recipe   Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("ingredients")
}

// PreparationStep model (New Model for SQL)
model PreparationStep {
  id          String @id @default(cuid())
  description String
  order       Int
  
  // Relation back to Recipe
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("preparation_steps")
}

// Rating model
model Rating {
  id          String   @id @default(cuid())
  ratingValue Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recipeId, userId])
  @@map("ratings")
}
